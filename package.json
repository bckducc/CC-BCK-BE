{
  "name": "bck-manager-backend",
  "version": "1.0.0",
  "description": "Backend for BCK Manager - Apartment Management System",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:security": "vitest run tests/security",
    "test:logic": "vitest run tests/logic",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:performance": "artillery run tests/performance/load-test.yml",
    "test:smoke": "vitest run tests/smoke"
  },
  "keywords": [
    "apartment",
    "management",
    "landlord"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.11.2",
    "jsonwebtoken": "^9.0.0",
    "mysql2": "^3.6.5",
    "pdfkit": "^0.16.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "artillery": "^2.0.30",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2",
    "supports-color": "^10.2.2",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.5"
  }
}
